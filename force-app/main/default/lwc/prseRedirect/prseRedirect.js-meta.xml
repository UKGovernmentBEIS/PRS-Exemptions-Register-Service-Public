<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property 
                name="redirectUrl" 
                type="String" 
                label="Url to redirect to" 
                required="false" 
                default="" 
                description="Url of the page you would like to be navigated to on component load."
            />
            <property
                name="externalLink"
                type="Boolean"
                required="false"
                label="Link navigation outside of Salesforce"
                description="Set to true if navigating outside of Salesforce"
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>