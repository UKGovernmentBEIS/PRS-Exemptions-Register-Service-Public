              "definition" : "c:gdsStartButton",
              "id" : "6a9d99dd-ec76-4443-af61-5a9fb624c8a0",
              "type" : "component"
            }, {
              "attributes" : {
                "dxpStyle" : { },
                "markupText" : "<section class=\"govuk-section govuk-!-margin-top-9\">   <h2 class=\"govuk-heading-l\">Access the service</h2>   <p class=\"govuk-body\">     You will access the service using <strong>One Login</strong>. You can create a One Login account at this point if you do not already have one.   </p>   <p class=\"govuk-body\">     One Login is the way to access many government services.   </p>    <div class=\"govuk-inset-text\">     <p class=\"govuk-body\">       <a class=\"govuk-link\" href=\"#\">Create or sign in to your One Login account</a>     </p>   </div> </section>  <section class=\"govuk-section govuk-!-margin-top-9\">   <h2 class=\"govuk-heading-l\">Support using digital services</h2>   <p class=\"govuk-body\">     If you need help to register an exemption, you can contact us:   </p>    <ul class=\"govuk-list\">     <li>Email: <a class=\"govuk-link\" href=\"mailto:meesdigital@energysecurity.gov.uk\">meesdigital@energysecurity.gov.uk</a></li>     <li>Telephone: <strong>0800 098 7950</strong></li>   </ul>    <div class=\"govuk-inset-text\">     <p class=\"govuk-body\">       This service will not provide advice on exemptions. If you are unsure which exemption to register, you can       <a class=\"govuk-link\" href=\"#\">read our guidance</a> or seek legal advice.     </p>   </div> </section>"
              },
              "definition" : "uxgovuk:govMarkupText",
