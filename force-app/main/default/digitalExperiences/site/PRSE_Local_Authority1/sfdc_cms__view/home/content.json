                "dxpStyle" : { },
                "markupText" : "<div class=\"govuk-width-container\">     <main class=\"govuk-main-wrapper\" id=\"main-content\" role=\"main\">         <h1 class=\"govuk-heading-xl\">Review exemptions for private rented sector energy standards</h1>         <div class=\"govuk-body\">             <p class=\"govuk-body\">Use this service to:</p>             <ul class=\"govuk-list govuk-list--bullet\">                 <li>review exemptions for private rented sector energy standards (PRSE <br>                     MEES) that have been registered in your local authority area                 </li>                 <li>record penalties that have been issued to landlords                 </li>             </ul>             <p class=\"govuk-body\">This service is for local authorities only.         </div>         <h2 class=\"govuk-heading-m\">To start using this service</h2>         <p class=\"govuk-body\"><a href=\"https://google.co.uk\"                     class=\"govuk-link\" rel=\"noreferrer noopener\" target=\"_blank\">Complete our local authority sign up form if you have not already done so.                 </a>         <div class=\"govuk-body\">             <p class=\"govuk-body\">You will need:</p>             <ul class=\"govuk-list govuk-list--bullet\">                 <li>to use the email address you have in the sign up form</li>                 <li>log in through your government One Login account - this invitation was <br>                     emailed to you by our team</li>             </ul>         </div>"
              },
